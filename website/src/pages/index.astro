      :global(.demo-code .comment) { color: #7f8797; }
      .demo-code .prompt,
      :global(.demo-code .prompt) { color: #a6e3a1; }
      .demo-code .err,
      :global(.demo-code .err) { color: #ff6b6b; }
      .demo-code .tip,
      :global(.demo-code .tip) { color: #f9e2af; }
      .demo-code .picker-muted,
      :global(.demo-code .picker-muted) { color: #8790a3; }
      .demo-code .picker-item,
      :global(.demo-code .picker-item) { color: #d7dbea; }
      .demo-code .picker-item--active,
      :global(.demo-code .picker-item--active) {
        color: #8bd5ca;
        font-weight: 600;
      }
      .demo-code .typed,
      :global(.demo-code .typed) { color: #eef1f8; }
      .demo-code .cursor,
      :global(.demo-code .cursor) {
        display: inline-block;
        width: 0.52em;
        height: 1.1em;
        margin-left: 0.08em;
        vertical-align: -0.18em;
        background: #eef1f8;
        animation: terminal-cursor 920ms steps(1) infinite;
      }

      @keyframes terminal-cursor {
        0%, 48% { opacity: 1; }
        49%, 100% { opacity: 0; }
      }

      section { padding: 3.5rem 0; }
      section h2 {
        font-size: clamp(1.5rem, 2vw, 1.85rem);
        margin: 0 0 2rem;
      }
      .example-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(3, 1fr);
      }

      .example-grid article {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 1.25rem;
      }

      /* Why Spellbook — 6 detailed feature cards in 2-col grid */
      .why__lede {
        margin: -1rem 0 2.25rem;
        color: var(--fg-muted);
        font-size: 1rem;
        max-width: 56ch;
      }
      .why-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
      }
      .why-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 0.85rem;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        position: relative;
        transition: border-color 200ms ease, transform 200ms ease;
      }
      .why-card:hover {
        border-color: rgba(155, 92, 220, 0.4);
        transform: translateY(-2px);
      }
      .why-card__head {
        display: flex;
        align-items: baseline;
        gap: 0.85rem;
      }
      .why-card__num {
        font-family: 'Geist Mono', ui-monospace, SFMono-Regular, monospace;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--accent-2);
        letter-spacing: 0.08em;
        flex-shrink: 0;
        padding: 0.15rem 0.5rem;
        border-radius: 0.35rem;
        background: rgba(61, 217, 161, 0.12);
        border: 1px solid rgba(61, 217, 161, 0.3);
      }
      .why-card h3 {
        margin: 0;
        font-size: 1.05rem;
        line-height: 1.3;
      }
      .why-card p {
        margin: 0;
        color: var(--fg-muted);
        font-size: 0.92rem;
        line-height: 1.55;
      }
      .why-card code {
        font-size: 0.85em;
        padding: 0.05rem 0.35rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--fg);
      }
      .why-card .snippet pre code {
        background: transparent;
        border: none;
        padding: 0;
        font-size: inherit;
      }

      .why-card--wide { grid-column: 1 / -1; }

      /* Comparison — three rows, each split into bad-left / good-right */
      .compare-stack {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .compare-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        align-items: stretch;
        position: relative;
      }
      .compare-row::before {
        content: '→';
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        color: var(--fg);
        background: var(--bg-card);
        border: 1px solid var(--border);
        box-shadow: 0 4px 14px -4px rgba(0, 0, 0, 0.5);
      }
      .compare-side {
        border-radius: 0.75rem;
        padding: 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        position: relative;
      }
      .compare-side h3 {
        margin: 0;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .compare-side pre { margin: 0; }
      .compare-side--bad {
        background:
          radial-gradient(120% 80% at 0% 0%,
            rgba(217, 124, 124, 0.18) 0%,
            transparent 55%),
          linear-gradient(180deg,
            rgba(217, 124, 124, 0.12) 0%,
            rgba(217, 124, 124, 0.04) 100%),
          var(--bg-card);
        border: 1px solid rgba(217, 124, 124, 0.32);
        box-shadow:
          0 0 0 1px rgba(217, 124, 124, 0.08),
          0 14px 40px -20px rgba(217, 124, 124, 0.32);
      }
      .compare-side--good {
        background:
          linear-gradient(180deg,
            rgba(61, 217, 161, 0.14) 0%,
            rgba(63, 184, 201, 0.08) 35%,
            rgba(106, 120, 214, 0.08) 70%,
            rgba(155, 92, 220, 0.14) 100%),
          var(--bg-card);
        border: 1px solid transparent;
        background-clip: padding-box;
        box-shadow:
          0 -10px 40px -20px rgba(61, 217, 161, 0.4),
          0 16px 44px -18px rgba(155, 92, 220, 0.5);
      }
      .compare-side--good::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(180deg,
          rgba(61, 217, 161, 0.7) 0%,
          rgba(63, 184, 201, 0.5) 35%,
          rgba(106, 120, 214, 0.5) 70%,
          rgba(155, 92, 220, 0.7) 100%);
        -webkit-mask:
          linear-gradient(#000 0 0) content-box,
          linear-gradient(#000 0 0);
        -webkit-mask-composite: xor;
                mask-composite: exclude;
        pointer-events: none;
      }

      .cons,
      .pros {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
      }
      .cons li,
      .pros li {
        padding-left: 1.85rem;
        position: relative;
        line-height: 1.5;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .cons li strong,
      .pros li strong {
        font-size: 0.98rem;
        font-weight: 600;
        color: var(--fg);
      }
      .cons li span,
      .pros li span {
        font-size: 0.88rem;
        color: var(--fg-muted);
      }
      .cons li::before,
      .pros li::before {
        position: absolute;
        left: 0;
        top: 0.05rem;
        width: 1.3rem;
        height: 1.3rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 700;
        line-height: 1;
      }
      .cons li::before {
        content: '✕';
        background: rgba(217, 124, 124, 0.18);
        color: #e89494;
        border: 1px solid rgba(217, 124, 124, 0.45);
      }
      .pros li::before {
        content: '✓';
        background: rgba(61, 217, 161, 0.16);
        color: var(--accent-2);
        border: 1px solid rgba(61, 217, 161, 0.45);
      }
      .cons li code,
      .pros li code {
        font-size: 0.85em;
        padding: 0.05rem 0.35rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--fg);
      }
      .pros li em {
        font-style: italic;
        color: var(--accent-2);
      }

      /* Install bar — single pill with method dropdown + command + copy */
      .install {
        max-width: 920px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
        padding-top: 0.75rem;
      }
      .install__cta {
        display: flex;
        justify-content: center;
        margin: 0 0 2.35rem;
      }
      .install-bar {
        position: relative;
        display: flex;
        width: 100%;
        align-items: stretch;
        gap: 0;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        padding: 0.35rem;
        backdrop-filter: blur(20px) saturate(140%);
        -webkit-backdrop-filter: blur(20px) saturate(140%);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.1),
          0 14px 40px -16px rgba(0, 0, 0, 0.7);
      }
      .install-bar__trigger {
        appearance: none;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.08);
        color: var(--fg);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 150ms ease, border-color 150ms ease;
      }
      .install-bar__trigger:hover {
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(155, 92, 220, 0.5);
      }
      .install-bar__trigger:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      .install-bar__chevron {
        opacity: 0.7;
        transition: transform 150ms ease;
      }
      .install-bar__trigger[aria-expanded='true'] .install-bar__chevron {
        transform: rotate(180deg);
      }

      /* Whole right side (command + icon) is one big copy button.
         No padding/radius of its own — uses parent .install-bar's pill shape
         via clip-path so the hover background reaches the rounded edges. */
      .install-bar__cmd-btn {
        appearance: none;
        flex: 1;
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: transparent;
        color: var(--fg);
        border: none;
        padding: 0 0.45rem 0 1rem;
        margin: -0.35rem -0.35rem -0.35rem 0;
        align-self: stretch;
        cursor: pointer;
        text-align: left;
        border-radius: 0 999px 999px 0;
        transition: background 150ms ease;
      }
      .install-bar__cmd-btn:hover { background: rgba(255, 255, 255, 0.05); }
      .install-bar__cmd-btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: -2px;
      }
      .install-bar__cmd-btn:disabled {
        cursor: default;
        background: transparent;
      }

      .install-bar__cmd {
        flex: 1;
        min-width: 0;
        font-family: 'Geist Mono', ui-monospace, SFMono-Regular, monospace;
        font-size: 0.88rem;
        color: var(--fg);
        overflow-x: auto;
        white-space: nowrap;
      }
      .install-bar__hint {
        flex: 1;
        min-width: 0;
        font-size: 0.88rem;
        color: var(--fg-muted);
      }

      /* Copy / check icon swap — bare icon, no background */
      .install-bar__copy-icon {
        flex-shrink: 0;
        width: 1.8rem;
        height: 1.8rem;
        margin-right: 0.75rem;
        color: var(--fg-muted);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        transition: color 150ms ease;
      }
      .install-bar__copy-icon svg {
        position: absolute;
        transition: opacity 180ms ease, transform 180ms ease;
      }
      .install-bar__copy-icon .icon-check {
        opacity: 0;
        transform: scale(0.7);
      }
      .install-bar__cmd-btn:hover .install-bar__copy-icon {
        color: var(--fg);
      }
      .install-bar__cmd-btn[data-state='done'] .install-bar__copy-icon {
        color: var(--accent-2);
      }
      .install-bar__cmd-btn[data-state='done'] .icon-copy {
        opacity: 0;
        transform: scale(0.7);
      }
      .install-bar__cmd-btn[data-state='done'] .icon-check {
        opacity: 1;
        transform: scale(1);
      }

      /* Dropdown menu */
      .install-bar__menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 0;
        z-index: 30;
        min-width: 16rem;
        list-style: none;
        margin: 0;
        padding: 0.4rem;
        background: var(--bg-card);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 0.65rem;
        box-shadow: 0 18px 44px -12px rgba(0, 0, 0, 0.7);
        text-align: left;
      }
      .install-bar__menu li {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.55rem 0.75rem;
        border-radius: 0.45rem;
        cursor: pointer;
        transition: background 120ms ease;
      }
      .install-bar__menu li:hover,
      .install-bar__menu li[aria-selected='true'] {
        background: rgba(155, 92, 220, 0.14);
      }
      .install-bar__menu-key {
        font-weight: 600;
        font-size: 0.92rem;
        color: var(--fg);
      }
      .install-bar__menu-desc {
        font-size: 0.78rem;
        color: var(--fg-muted);
      }
      .install-bar__menu-desc code {
        font-family: 'Geist Mono', ui-monospace, monospace;
        font-size: 0.85em;
        padding: 0.05rem 0.3rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.06);
      }

      .install__hint {
        margin: 1rem auto 0;
        max-width: 64ch;
        font-size: 0.92rem;
        color: var(--fg-muted);
        line-height: 1.6;
      }
      .install__hint code {
        font-size: 0.85em;
        padding: 0.05rem 0.35rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.06);
      }

      /* Manual install — step-by-step list shown when "Manual" is selected */
      .install__manual {
        margin: 1.5rem 0 0;
        text-align: left;
      }
      .manual-steps {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 1rem;
      }
      .manual-steps > li {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 0.85rem;
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      .manual-steps h4 {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
        color: var(--fg);
      }
      .manual-steps p {
        margin: 0;
        color: var(--fg-muted);
        font-size: 0.92rem;
        line-height: 1.55;
      }
      .manual-steps p code,
      .manual-steps h4 code {
        font-size: 0.85em;
        padding: 0.05rem 0.35rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 0.25rem;
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--fg);
      }
      .manual-steps a {
        color: #c8a5f0;
        text-decoration: underline;
        text-decoration-color: rgba(155, 92, 220, 0.4);
      }
      .manual-steps a:hover { text-decoration-color: var(--accent); }

      @media (max-width: 720px) {
        .install-bar {
          flex-wrap: wrap;
          border-radius: 1.1rem;
          width: 100%;
        }
        .install-bar__cmd {
          flex-basis: 100%;
          padding: 0.65rem 1rem;
          border-top: 1px solid rgba(255, 255, 255, 0.06);
          margin-top: 0.35rem;
        }
        .install-bar__menu {
          min-width: 100%;
        }
      }

      .example-grid pre {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 0.85rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        font-size: 0.85rem;
        margin: 0.5rem 0 0.75rem;
      }

      /* Labelled snippet (file vs terminal) — used in compare + why sections */
      .snippet {
        display: flex;
        flex-direction: column;
      }
      .snippet__label {
        font-family: 'Geist Mono', ui-monospace, SFMono-Regular, monospace;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--fg-muted);
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-bottom: none;
        padding: 0.35rem 0.75rem;
        border-radius: 0.5rem 0.5rem 0 0;
      }
      .snippet pre {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 0.85rem;
        border-radius: 0 0 0.5rem 0.5rem;
        overflow-x: auto;
        font-size: 0.85rem;
        margin: 0;
        line-height: 1.55;
      }
      .snippet--err .snippet__label {
        color: #e89494;
        border-color: rgba(217, 124, 124, 0.4);
        background: rgba(217, 124, 124, 0.12);
      }
      .snippet--err pre {
        border-color: rgba(217, 124, 124, 0.32);
        background:
          linear-gradient(180deg,
            rgba(217, 124, 124, 0.08) 0%,
            transparent 60%),
          rgba(0, 0, 0, 0.45);
      }
      .example-grid a { color: var(--accent-2); text-decoration: none; }
      .example-grid a:hover { text-decoration: underline; }

      .cta {
        text-align: center;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        margin: 3rem 0;
      }
      .cta .hero__cta { justify-content: center; }

      .site-footer {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 0.9rem;
        color: var(--fg-muted);
      }
      .copyright { margin: 0; }
      .footer-links { display: flex; gap: 1.25rem; }
      .footer-links a { color: var(--fg-muted); text-decoration: none; }
      .footer-links a:hover { color: var(--fg); }

      @media (max-width: 900px) {
        .hero { grid-template-columns: 1fr; padding: 2.5rem 0; }
        .why-grid,
        .example-grid { grid-template-columns: 1fr; }
        .compare-row { grid-template-columns: 1fr; gap: 1rem; }
        .compare-row::before {
          content: '↓';
          left: 50%;
          top: 50%;
          transform: translate(-50%, -50%);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .demo-code,
        .demo-code .cursor { animation: none; transition: none; }
      }
    </style>
  </body>
</html>
