    <script>
      function wireCopy() {
        document.querySelectorAll<HTMLButtonElement>('button[data-target]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const id = btn.dataset.target;
            if (!id) return;
            const target = document.getElementById(id);
            const text = target?.textContent ?? '';
            try {
              await navigator.clipboard.writeText(text.trim());
              const original = btn.textContent;
              btn.textContent = 'Copied';
              setTimeout(() => { btn.textContent = original; }, 1600);
            } catch {
              btn.textContent = 'Copy failed';
            }
          });
        });
      }
      function wireInstallBar() {
        const bar = document.querySelector<HTMLDivElement>('.install-bar');
        const trigger = document.getElementById('install-trigger');
        const menu = document.getElementById('install-menu');
        const copyBtn = document.getElementById('install-copy') as HTMLButtonElement | null;
        const cmd = document.querySelector<HTMLElement>('[data-install-cmd]');
        const label = document.querySelector<HTMLElement>('[data-install-label]');
        const barHint = document.querySelector<HTMLElement>('[data-install-bar-hint]');
        const hint = document.querySelector<HTMLElement>('[data-install-hint]');
        const manual = document.querySelector<HTMLElement>('[data-install-manual]');
        if (!bar || !trigger || !menu || !copyBtn || !cmd || !label) return;

        const COMMANDS: Record<string, { label: string; cmd: string; hint?: string; pageHint?: string }> = {
          curl: {
            label: 'curl',
            cmd: 'curl -fsSL https://raw.githubusercontent.com/Nikoro/spellbook/main/install.sh | sh',
            pageHint: 'macOS only. The curl installer auto-detects your shell (zsh / bash / fish), checks <code>~/.local/bin</code> on <code>$PATH</code>, and prompts before adding the integration to your rc file.',
          },
          brew: {
            label: 'Homebrew',
            cmd: 'brew install nikoro/tap/spellbook',
            pageHint: 'macOS only. Installs the <code>spells</code> binary into Homebrew\'s prefix. Brew can\'t edit your rc file, so finish setup by adding <code>eval "$(spells init zsh)"</code> (or <code>bash</code> / <code>fish</code>) to your shell config.',
          },
          manual: {
            label: 'Manual',
            cmd: '',
            hint: 'Same steps the curl installer runs — just spelled out below ↓',
          },
        };

        const close = () => {
          menu.setAttribute('hidden', '');
          trigger.setAttribute('aria-expanded', 'false');
        };
        const open = () => {
          menu.removeAttribute('hidden');
          trigger.setAttribute('aria-expanded', 'true');
        };

        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          if (menu.hasAttribute('hidden')) open();
          else close();
        });

        document.addEventListener('click', (e) => {
          if (!bar.contains(e.target as Node)) close();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') close();
        });

        const apply = (method: string) => {
          if (!COMMANDS[method]) return;
          label.textContent = COMMANDS[method].label;
          cmd.textContent = COMMANDS[method].cmd;
          bar.dataset.method = method;

          const isManual = method === 'manual';
          if (hint) {
            hint.toggleAttribute('hidden', isManual);
            const pageHint = COMMANDS[method].pageHint;
            if (pageHint) hint.innerHTML = pageHint;
          }
          if (manual) manual.toggleAttribute('hidden', !isManual);
          if (barHint) {
            if (isManual && COMMANDS[method].hint) {
              barHint.textContent = COMMANDS[method].hint!;
              barHint.removeAttribute('hidden');
            } else {
              barHint.setAttribute('hidden', '');
            }
          }
          // Hide the actual command + copy icon when in manual
          cmd.toggleAttribute('hidden', isManual);
          const icon = copyBtn.querySelector<HTMLElement>('[data-copy-icon]');
          if (icon) icon.toggleAttribute('hidden', isManual);
          // The whole bar is no longer a copy button in manual mode
          copyBtn.disabled = isManual;
        };

        menu.querySelectorAll<HTMLLIElement>('li[role="option"]').forEach((opt) => {
          opt.addEventListener('click', () => {
            const method = opt.dataset.method;
            if (!method) return;
            menu.querySelectorAll('li').forEach((li) => {
              li.setAttribute('aria-selected', li === opt ? 'true' : 'false');
            });
            apply(method);
            close();
          });
        });

        // Sync DOM with the initially selected option on first paint.
        const initial = (menu.querySelector('li[aria-selected="true"]') as HTMLLIElement | null)
          ?.dataset.method ?? 'curl';
        apply(initial);

        // Click anywhere on the command button → copy
        copyBtn.addEventListener('click', async () => {
          if (copyBtn.disabled) return;
          const text = (cmd.textContent ?? '').trim();
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            copyBtn.dataset.state = 'done';
            window.setTimeout(() => {
              if (copyBtn.dataset.state === 'done') copyBtn.dataset.state = 'idle';
            }, 1800);
          } catch {
            copyBtn.dataset.state = 'error';
            window.setTimeout(() => { copyBtn.dataset.state = 'idle'; }, 1800);
          }
        });
      }
      function wireHeroDemo() {
        const windowEl = document.querySelector<HTMLElement>('[data-demo-window]');
        const terminal = document.querySelector<HTMLElement>('[data-demo-terminal]');
        if (!windowEl || !terminal) return;

        const frames = [
          {
            step: '1',
            commands: [
              { input: 'hello', output: ['Hello World'] },
            ],
          },
          {
            step: '2',
            commands: [
              {
                input: 'hello',
                output: [
                  "<span class=\"err\">error: missing required param 'name' in 'hello'</span>",
                  '<span class="tip">tip: Provide &lt;name&gt;</span>',
                ],
              },
              { input: 'hello Bob', output: ['Hello Bob'] },
            ],
          },
          {
            step: '3',
            commands: [
              {
                input: 'hello',
                output: [
                  "<span class=\"err\">error: missing required param 'name' in 'hello'</span>",
                  '<span class="tip">tip: Provide -n, --name</span>',
                ],
              },
              { input: 'hello -n Ann', output: ['Hello Ann'] },
            ],
          },
          {
            step: '4',
            commands: [
              { input: 'hello', output: ['Hello John'] },
            ],
          },
          {
            step: '5',
            commands: [
              {
                input: 'hello',
                picker: [
                  '<span class="picker-item picker-item--active">&gt; Bob</span>',
                  '<span class="picker-item">  Ann</span>',
                  '<span class="picker-item">  John</span>',
                ],
                pickedPicker: [
                  '<span class="picker-item">  Bob</span>',
                  '<span class="picker-item picker-item--active">&gt; Ann</span>',
                  '<span class="picker-item">  John</span>',
                ],
                output: ['Hello Ann'],
              },
            ],
          },
          {
            step: '6',
            commands: [
              {
                input: 'hello --help',
                outputDelay: 760,
                holdAfter: 3600,
                output: [
                  [
                    'hello — Greet someone by name',
                    '',
                    'Parameters:',
                    '  -n, --name &lt;string&gt;  Person to greet  (default: World)',
                  ],
                ],
              },
            ],
          },
        ];

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const wait = (ms: number) => new Promise((resolve) => window.setTimeout(resolve, ms));
        const renderPrompt = (input = '') => {
          terminal.innerHTML = `<span class="prompt">$</span> <span class="typed">${input}</span><span class="cursor"></span>`;
        };
        const appendLine = (html: string) => {
          terminal.insertAdjacentHTML('beforeend', `\n${html}`);
        };
        const renderPicker = async (items: string[], pickedItems?: string[]) => {
          const promptLine = terminal.innerHTML.split('\n')[0];
          terminal.innerHTML = [promptLine, ...items].join('\n');
          await wait(760);
          if (pickedItems) {
            terminal.innerHTML = [promptLine, ...pickedItems].join('\n');
            await wait(920);
            await wait(320);
          }
        };

        const typeCommand = async (input: string) => {
          renderPrompt();
          await wait(520);
          const typed = terminal.querySelector<HTMLElement>('.typed');
          if (!typed) return;
          for (const char of input) {
            typed.textContent += char;
            await wait(72 + Math.random() * 48);
          }
          await wait(760);
          terminal.querySelector('.cursor')?.remove();
        };

        const playFrame = async (frame: typeof frames[number]) => {
          windowEl.dataset.demoStep = frame.step;
          terminal.innerHTML = '';
          await wait(1450);
          for (const command of frame.commands) {
            await typeCommand(command.input);
            await wait(280);
            if ('picker' in command && command.picker) {
              await renderPicker(command.picker, command.pickedPicker);
            }
            for (const output of command.output) {
              if (Array.isArray(output)) {
                for (const line of output) appendLine(line);
              } else {
                appendLine(output);
              }
              await wait(command.outputDelay ?? 440);
            }
            await wait(command.holdAfter ?? 980);
          }
          await wait(1250);
        };

        if (reduceMotion) {
          windowEl.dataset.demoStep = '5';
          terminal.innerHTML = `<span class="prompt">$</span> hello --help
hello — Greet someone by name

Parameters:
  -n, --name &lt;string&gt;  Person to greet  (default: World)`;
          return;
        }

        const loop = async () => {
          let index = 0;
          while (true) {
            await playFrame(frames[index]);
            index = (index + 1) % frames.length;
          }
        };

        void loop();
      }
      wireCopy();
      wireInstallBar();
      wireHeroDemo();
    </script>

